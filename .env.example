# 스냅샷을 찍을 프론트엔드 주소
FRONTEND_URL=https://zzzin.net

# 서버 포트 (선택, 기본값: 6666)
# PORT=6666

# 업로더 종류: s3 또는 local
UPLOADER=s3
# UPLOADER=local 일 때 저장 경로 (선택, 기본값: ./uploads)
# LOCAL_UPLOAD_DIR=./uploads

# S3 설정 (UPLOADER=s3 일 때 필수)
S3_BUCKET=your-bucket-name
S3_REGION=ap-northeast-2
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
